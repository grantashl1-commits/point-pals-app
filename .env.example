# PointPals configuration example. Copy to .env and fill in.
# Client vars must be prefixed VITE_ to be exposed to the browser build.
# Do NOT put secret keys (Stripe secret, service role) in VITE_ vars — those
# live only in Supabase Edge Function secrets (see docs/OPERATIONS.md).

# --- Supabase (client) ---
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-or-publishable-key"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT"

# --- Stripe (client-facing Price IDs only; secret keys are function secrets) ---
# One Price ID per currency so adding a currency is config, not code.
VITE_STRIPE_PRICE_NZD=""
VITE_STRIPE_PRICE_AUD=""
VITE_STRIPE_PRICE_USD=""

# --- RevenueCat (native iOS/Android in-app purchases) ---
# PUBLIC app-specific SDK keys (safe in the client), one per store. Find them in
# RevenueCat → Project → API keys. These are NOT the docs' sample `test_…` key
# and NOT a secret key. Web/PWA ignores these and uses Stripe above.
VITE_RC_IOS_KEY=""
VITE_RC_ANDROID_KEY=""

# --- Product analytics (PostHog) — optional; app runs fine without it ---
# Parent-facing actions only; no session recording; kid events are anonymised.
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# --- Error tracking (Sentry) — optional; PII is scrubbed before send ---
VITE_SENTRY_DSN=""

# ---------------------------------------------------------------------------
# Server-only secrets — set these as Supabase Edge Function secrets, NOT here:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set STRIPE_PRICE_NZD=price_...
#   supabase secrets set REVENUECAT_WEBHOOK_AUTH=<shared-secret>   # revenuecat-webhook
#   (SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are injected automatically)
# ---------------------------------------------------------------------------
